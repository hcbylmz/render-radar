{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "types": ["jest"]
  },
  "include": ["src"],
  "exclude": [
    "lib",
    "node_modules",
    "example",
    "**/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
