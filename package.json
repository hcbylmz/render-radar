{
  "name": "render-radar",
  "version": "0.1.0",
  "description": "Dev-only re-render visualizer for React Native — flash + count every render.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build": "bob build",
    "prepare": "bob build",
    "prepublishOnly": "jest && tsc --noEmit"
  },
  "author": "Hicabi Yılmaz",
  "keywords": [
    "react-native",
    "performance",
    "render",
    "devtools",
    "debug",
    "rerender"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.3",
    "react-native": ">=0.74"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.76.5",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.31",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.5",
    "react-native-builder-bob": "^0.30.3",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.9.3"
  }
}
